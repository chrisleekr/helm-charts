# Env vars the parity gate (scripts/check-env-parity.sh) should ignore, on either
# direction. One name per line. Keep this list minimal and justified: every entry
# is a conscious decision NOT to mirror a config.ts var 1:1.
#
# --- Chart-only infra vars (not in github-app's env-contract) ---
# Docker-in-Docker daemon socket for docker-heavy daemon pools; a Kubernetes/
# container concern, not app config.
DOCKER_HOST

# --- Contract vars intentionally not surfaced in the chart (rely on app defaults) ---
# Internal tuning knobs with sensible defaults; expose via extraEnv if ever needed.
WORKSPACE_STALE_TTL_MS
FLEET_SNAPSHOT_INTERVAL_MS
GITHUB_API_SLOW_REQUEST_MS
# Socket-health watchdog knobs (github-app #265). Diagnostic CLOSE_WAIT spin
# detector with sensible defaults and consumer-side clamps; self-heal is opt-in
# and off by default. Same family as FLEET_SNAPSHOT_INTERVAL_MS above.
SOCKET_HEALTH_INTERVAL_MS
SOCKET_HEALTH_LEAK_SAMPLES
SOCKET_HEALTH_SELF_HEAL_SAMPLES
SOCKET_HEALTH_CPU_PERCENT
SOCKET_HEALTH_SELF_HEAL_ENABLED
